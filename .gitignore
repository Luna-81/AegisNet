cat << 'EOF' > .gitignore
# === 编译与构建输出 ===
build/
bin/
lib/
out/
dist/
# 忽略 CMake 自动生成的中间文件
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
cmake_build_debug/
cmake_build_release/

# === 目标可执行文件 ===
# 这里添加你 CMakeLists.txt 中 add_executable 定义的名字
AegisNetServer
*.exe
*.out
*.app

# === IDE 与编辑器相关 ===
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (CLion / PyCharm)
.idea/

# Vim 临时文件
*.swp
*.swo
*~

# === 系统与日志文件 ===
.DS_Store
Thumbs.db
*.log
*.tmp

# === 静态分析与调试 ===
*.gcov
*.gcda
*.gcno
EOF